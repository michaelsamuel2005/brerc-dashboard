# Normalise line endings so the repo is consistent across macOS/Linux/Windows.
* text=auto eol=lf

# Explicit text types.
*.py     text
*.ts     text
*.tsx    text
*.js     text
*.cjs    text
*.json   text
*.sql    text
*.md     text
*.yml    text
*.yaml   text
*.css    text
*.html   text
*.toml   text
Dockerfile text
Makefile text
*.sh     text eol=lf

# Binary types (never normalise).
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary

# Keep generated / vendored files out of language stats and diffs.
web/package-lock.json  linguist-generated=true
