# ---------------------------------------------------------------------------
# BRERC Public Dashboard — environment template
#
# Copy to `.env` and fill in. `.env` is git-ignored and must never be committed.
#
# Dev -> prod is a CREDENTIALS-ONLY change (Decisions_Log D-005): to point at
# BRERC production, change DATABASE_URL / PUBLIC_DATABASE_URL only. No code or
# query changes are required.
# ---------------------------------------------------------------------------

# --- PostgreSQL / PostGIS ---------------------------------------------------
# The migration/seed superuser connection (dev only; used by `make db-*`).
# In production BRERC administers the database; the app never needs this role.
POSTGRES_USER=brerc
POSTGRES_PASSWORD=change_me_in_local_env_only
POSTGRES_DB=brerc
POSTGRES_HOST=db
POSTGRES_PORT=5432

# The application connection string. The app connects with a READ-ONLY role
# (see db/migrations/0006_roles.sql). Never point the app at a superuser role.
#   dev:  postgresql://brerc_readonly:...@db:5432/brerc
#   prod: <BRERC-supplied read-only credentials>   <-- the only change at handover
PUBLIC_DATABASE_URL=postgresql://brerc_readonly:change_me@db:5432/brerc

# Password for the read-only application role, set at DB init.
BRERC_READONLY_PASSWORD=change_me

# --- Martin (vector tile server) -------------------------------------------
# Martin reads tiles from the public_occurrences generalised layer ONLY.
MARTIN_PORT=3000

# --- FastAPI service --------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated allow-list for CORS. Same-origin deployment needs none;
# during local dev the Vite dev server origin is allowed.
API_CORS_ORIGINS=http://localhost:5173
# Row cap and statement timeout (ms) applied to every user-facing query.
API_MAX_ROWS=5000
API_STATEMENT_TIMEOUT_MS=5000
# Contact e-mail sent in the User-Agent when calling iNaturalist/GBIF/Wikipedia
# (their usage policies expect an identifying User-Agent).
SPECIES_INFO_USER_AGENT=BRERC-Dashboard/0.1 (+https://www.brerc.org.uk; contact@example.org)
# Cache TTL for fetched species-info records, in days.
SPECIES_INFO_CACHE_TTL_DAYS=30

# --- Web front end ----------------------------------------------------------
# The browser calls these paths. Same-origin behind the proxy, so the built app
# defaults to RELATIVE /api and /tiles and needs neither variable in production.
# Set them only to point a build at a different origin (which then needs CORS).
# (The initial map view is set in web/src/config.ts.)
# VITE_API_BASE=/api
# VITE_TILES_BASE=/tiles
# For the local Vite dev server (`npm run dev`), point the dev proxy upstreams:
# VITE_DEV_API_TARGET=http://localhost:8000
# VITE_DEV_TILES_TARGET=http://localhost:3000

# --- Proxy / ports ----------------------------------------------------------
PROXY_PORT=8080

# --- INTERNAL data-quality dashboard (SECONDARY, opt-in) --------------------
# OFF by default. When enabled (compose profile `internal`), the internal API
# exposes /internal/* which reads PRECISE data + recorder names via the
# brerc_internal_ro role. It is bound to localhost and is NEVER behind the public
# proxy. Serve it only on the internal network / behind SSO.
#   Enable the internal API service:  make internal-up
BRERC_INTERNAL_PASSWORD=change_me
INTERNAL_DATABASE_URL=postgresql://brerc_internal_ro:change_me@db:5432/brerc
INTERNAL_BASIC_AUTH_USER=staff
INTERNAL_BASIC_AUTH_PASSWORD=change_me
INTERNAL_API_PORT=8001

# --- Front-end data source -------------------------------------------------
# The front end uses realistic MOCK data by default, so it runs with NO backend.
# Set this to "false" (once the real API + tiles exist) to use them instead.
# VITE_USE_MOCKS=false
