# ---------------------------------------------------------------------------
# Front-end environment (web/). Everything here is PUBLIC — it ships in the
# browser bundle. NEVER put secrets, database credentials, or tokens here.
# The dev -> prod switch (R6) changes only these URLs; no code changes.
# Copy this file to `.env` (which is git-ignored) and adjust as needed.
# ---------------------------------------------------------------------------

# Base URL of the team's backend API the client talks to.
# Dev: the MSW mock intercepts these calls, so any value works.
VITE_API_BASE_URL=/api

# A public, CSP-compatible MapLibre style JSON (the basemap). No provider key.
VITE_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# Vector-tile endpoint template for the distribution grid cells (server-aggregated).
VITE_TILE_URL=/api/distribution/tiles/{z}/{x}/{y}.mvt
